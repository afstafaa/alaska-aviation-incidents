{
  "name": "node-playwright-mcp",
  "version": "0.1.0",
  "description": "Minimal remote MCP server with Playwright for container hosts",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "express": "^4.19.2",
    "playwright": "^1.53.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.1",
    "tsx": "^4.20.0",
    "typescript": "^5.8.3"
  }
}
